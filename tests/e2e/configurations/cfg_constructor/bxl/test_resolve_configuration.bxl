load("@prelude//:asserts.bzl", "asserts")
load("@prelude//cfg/modifier:common.bzl", "add_to_constraint_setting_to_modifier_infos", "resolve_configuration")
load("@prelude//cfg/modifier:types.bzl", "ModifiersMatchInfo")
load(":util.bxl", "TestRefs", "get_test_refs")

def test_single_constraint_value(test_refs: TestRefs):
    linux_cv = test_refs.get("ovr_config//os/constraints:linux")[ConstraintValueInfo]

    constraint_setting_to_modifier_infos = {}
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, linux_cv.setting.label, linux_cv)

    platform = resolve_configuration(constraint_setting_to_modifier_infos)

    expected_cfg = test_refs.make_cfg(["ovr_config//os/constraints:linux"])
    asserts.equals(expected_cfg, platform.configuration)
    asserts.equals("cfg:linux", platform.label)

def test_multiple_constraint_values(test_refs: TestRefs):
    linux_cv = test_refs.get("ovr_config//os/constraints:linux")[ConstraintValueInfo]
    x86_64_cv = test_refs.get("ovr_config//cpu/constraints:x86_64")[ConstraintValueInfo]

    constraint_setting_to_modifier_infos = {}
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, linux_cv.setting.label, linux_cv)
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, x86_64_cv.setting.label, x86_64_cv)

    platform = resolve_configuration(constraint_setting_to_modifier_infos)

    expected_cfg = test_refs.make_cfg(["ovr_config//os/constraints:linux", "ovr_config//cpu/constraints:x86_64"])
    asserts.equals(expected_cfg, platform.configuration)
    asserts.equals("cfg:linux-x86_64", platform.label)

def test_override_same_setting(test_refs: TestRefs):
    linux_cv = test_refs.get("ovr_config//os/constraints:linux")[ConstraintValueInfo]
    macos_cv = test_refs.get("ovr_config//os/constraints:macos")[ConstraintValueInfo]

    constraint_setting_to_modifier_infos = {}
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, linux_cv.setting.label, linux_cv)
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, macos_cv.setting.label, macos_cv)

    platform = resolve_configuration(constraint_setting_to_modifier_infos)

    expected_cfg = test_refs.make_cfg(["ovr_config//os/constraints:macos"])
    asserts.equals(expected_cfg, platform.configuration)
    asserts.equals("cfg:macos", platform.label)

def test_with_conditional_modifier(test_refs: TestRefs):
    linux_cv = test_refs.get("ovr_config//os/constraints:linux")[ConstraintValueInfo]
    asan_cv = test_refs.get("ovr_config//build_mode:sanitizer_type[asan]")[ConstraintValueInfo]
    nosan_cv = test_refs.get("ovr_config//build_mode:sanitizer_type[no-san]")[ConstraintValueInfo]

    # Conditional modifier: if linux -> asan, default -> no-san
    modifier_info = ModifiersMatchInfo(
        selector = [
            (test_refs.make_cfg(["ovr_config//os/constraints:linux"]), asan_cv),
        ],
        default = nosan_cv,
    )

    constraint_setting_to_modifier_infos = {}
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, linux_cv.setting.label, linux_cv)
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, asan_cv.setting.label, modifier_info)

    platform = resolve_configuration(constraint_setting_to_modifier_infos)

    expected_cfg = test_refs.make_cfg(["ovr_config//os/constraints:linux", "ovr_config//build_mode:sanitizer_type[asan]"])
    asserts.equals(expected_cfg, platform.configuration)

def test_topological_ordering(test_refs: TestRefs):
    # CPU modifier depends on OS: if linux -> x86_64, default -> arm64
    linux_cv = test_refs.get("ovr_config//os/constraints:linux")[ConstraintValueInfo]
    x86_64_cv = test_refs.get("ovr_config//cpu/constraints:x86_64")[ConstraintValueInfo]
    arm64_cv = test_refs.get("ovr_config//cpu/constraints:arm64")[ConstraintValueInfo]

    cpu_modifier = ModifiersMatchInfo(
        selector = [
            (test_refs.make_cfg(["ovr_config//os/constraints:linux"]), x86_64_cv),
        ],
        default = arm64_cv,
    )

    # Add CPU modifier first, then OS — resolve_configuration should
    # topologically sort so OS is resolved before CPU.
    constraint_setting_to_modifier_infos = {}
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, x86_64_cv.setting.label, cpu_modifier)
    add_to_constraint_setting_to_modifier_infos(constraint_setting_to_modifier_infos, linux_cv.setting.label, linux_cv)

    platform = resolve_configuration(constraint_setting_to_modifier_infos)

    expected_cfg = test_refs.make_cfg(["ovr_config//os/constraints:linux", "ovr_config//cpu/constraints:x86_64"])
    asserts.equals(expected_cfg, platform.configuration)
    asserts.equals("cfg:linux-x86_64", platform.label)

def test_empty_input():
    platform = resolve_configuration({})

    asserts.equals(ConfigurationInfo(constraints = {}, values = {}), platform.configuration)
    asserts.equals("cfg:<empty>", platform.label)

def _impl(ctx: bxl.Context):
    test_refs = get_test_refs(ctx)

    test_single_constraint_value(test_refs)
    test_multiple_constraint_values(test_refs)
    test_override_same_setting(test_refs)
    test_with_conditional_modifier(test_refs)
    test_topological_ordering(test_refs)
    test_empty_input()

test = bxl_main(
    cli_args = {},
    impl = _impl,
)
