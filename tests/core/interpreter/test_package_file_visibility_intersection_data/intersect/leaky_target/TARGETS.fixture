# Target inside the opted-in subtree (cap = `root//intersect/...`) but
# whose own `visibility = [...]` list extends OUTSIDE the cap. This is
# the footgun this feature is meant to fix: without the intersection
# model, the `root//leak_destination/...` entry in this list would let
# consumers in `root//leak_destination/` slip through the package
# wall. With the cap, those consumers are still blocked even though
# the target's own visibility allows them.
stub(
    name = "t",
    visibility = [
        "root//intersect/sub_b/...",
        "root//leak_destination/...",
    ],
)
