def _target_universe_keep_going_incompatible_list(ctx):
    result = ctx.target_universe([
        "//incompatible_targets:compatible_target",
        "//incompatible_targets:incompatible_target",
    ], keep_going = True).target_set()
    _assert_targets(ctx, result, ["//incompatible_targets:compatible_target"])

target_universe_keep_going_incompatible_list = bxl_main(
