{
    "comments": {
        "lineComment": "#"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*#.*$",
            "action": {
                "indentAction": "none",
                "appendText": "# "
            }
        }
    ],
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        {
            "open": "\"",
            "close": "\"",
            "notIn": ["string", "comment"]
        },
        {
            "open": "'",
            "close": "'",
            "notIn": ["string", "comment"]
        }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ]
}
