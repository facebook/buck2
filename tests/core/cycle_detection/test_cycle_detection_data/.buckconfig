[buildfile]
name=TARGETS.fixture

[project]
ignore=ignored

[cells]
  root = .
  nano_prelude = nano_prelude

[cell_aliases]
  prelude = nano_prelude

[external_cells]
  nano_prelude = bundled

[build]
  lazy_cycle_detector = true
  execution_platforms = //:execution_platforms

[buck2]
  detect_cycles = disabled
