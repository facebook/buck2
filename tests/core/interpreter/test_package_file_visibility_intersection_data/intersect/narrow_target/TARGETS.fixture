# Target declares its own non-PUBLIC list. The effective visibility is
# the AND of `root//intersect/sub_b/...` (declared) and
# `root//intersect/...` (cap) = `root//intersect/sub_b/...`. A consumer
# in `root//intersect/sub_a/...` matches the cap but NOT the target's
# own list, so it is rejected -- this is the footgun fix.
stub(
    name = "t",
    visibility = ["root//intersect/sub_b/..."],
)
