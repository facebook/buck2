def _get_package_path(ctx: bxl.Context):
    cnode = ctx.configured_targets("root//:dummy")
    configured_label = cnode.label
    label = configured_label.raw_target()
    configured_providers_label = configured_label.with_sub_target([])
    providers_label = label.with_sub_target([])

    asserts.equals(configured_label.package_path, label.package_path)
    asserts.equals(configured_label.package_path, configured_providers_label.package_path)
    asserts.equals(configured_label.package_path, providers_label.package_path)
    asserts.equals(str(configured_label.package_path), "root//")

    bar_dummy_node = ctx.configured_targets("root//bar_dir:bar_dummy")
    bar_dummy_label = bar_dummy_node.label
    asserts.equals(str(bar_dummy_label.package_path), "root//bar_dir")

get_package_path = bxl_main(
    impl = _get_package_path,
    cli_args = {},
)

def _read_package_value_impl(ctx):
    # Get an unconfigured target node
    node = ctx.unconfigured_targets("root//:dummy")
    pkg_path = node.label.package_path

    # Read package values using the package path from node
    value = bxl.read_package_value(pkg_path, "test.key")
    asserts.equals(value, "root_value")

    dict_value = bxl.read_package_value(pkg_path, "test.dict")
    asserts.equals(dict_value["name"], "root_dict")
    asserts.equals(dict_value["value"], 42)

read_package_value = bxl_main(
    impl = _read_package_value_impl,
    cli_args = {},
)

def _read_package_value_from_string_impl(_ctx):
    # Read package values using a package string
    value = bxl.read_package_value("root//sub_dir", "test.key")
    asserts.equals(value, "inner_value")

    dict_value = bxl.read_package_value("root//sub_dir", "test.dict")
    asserts.equals(dict_value["name"], "inner_dict")
    asserts.equals(dict_value["value"], 100)

    val = bxl.read_package_value("root//sub_dir", "test.sub_dir")
    asserts.equals(val, "value")

read_package_value_from_string = bxl_main(
    impl = _read_package_value_from_string_impl,
    cli_args = {},
)

def _read_override_package_value_impl(_ctx):
    value = bxl.read_package_value("root//", "test.key")
    asserts.equals(value, "root_value")

    override_value = bxl.read_package_value("root//sub_dir", "test.key")
    asserts.equals(override_value, "inner_value")

read_override_package_value = bxl_main(
    impl = _read_override_package_value_impl,
    cli_args = {},
)

def _read_package_value_not_found_impl(_ctx):
    # Read a package value that doesn't exist
    value = bxl.read_package_value("root//", "test.non_exist_key")
    asserts.equals(value, None)

read_package_value_not_found = bxl_main(
    impl = _read_package_value_not_found_impl,
    cli_args = {},
)

def _read_package_visibility_impl(ctx):
    # Default: `root//` declares no visibility, so it is visible to nothing (`[]`).
    # Exercise both the PackagePath form (from a node) and the string form.
    root_pkg_path = ctx.unconfigured_targets("root//:dummy").label.package_path
    asserts.equals(bxl.read_package_visibility(root_pkg_path), [])
    asserts.equals(bxl.read_package_visibility("root//"), [])

    # Explicit visibility declared in `vis_dir/PACKAGE`, via both input forms. The
    # `target_name_glob(...)` entry is rendered as a JSON object, not a string.
    vis_pkg_path = ctx.unconfigured_targets("root//vis_dir:vis_dummy").label.package_path
    expected = [
        "root//bar_dir/...",
        "root//sub_dir:",
        {"name_globs": ["*-test"], "within": [], "__type": "target_name_glob"},
    ]
    asserts.equals(bxl.read_package_visibility(vis_pkg_path), expected)
    asserts.equals(bxl.read_package_visibility("root//vis_dir"), expected)

read_package_visibility = bxl_main(
    impl = _read_package_visibility_impl,
    cli_args = {},
)

def _read_package_within_view_impl(ctx):
    # Default: `root//` declares no within_view, so it defaults to `["PUBLIC"]`.
    # Exercise both the PackagePath form (from a node) and the string form.
    root_pkg_path = ctx.unconfigured_targets("root//:dummy").label.package_path
    asserts.equals(bxl.read_package_within_view(root_pkg_path), ["PUBLIC"])
    asserts.equals(bxl.read_package_within_view("root//"), ["PUBLIC"])

    # Explicit within_view declared in `vis_dir/PACKAGE`, via both input forms.
    vis_pkg_path = ctx.unconfigured_targets("root//vis_dir:vis_dummy").label.package_path
    asserts.equals(bxl.read_package_within_view(vis_pkg_path), ["root//..."])
    asserts.equals(bxl.read_package_within_view("root//vis_dir"), ["root//..."])

read_package_within_view = bxl_main(
    impl = _read_package_within_view_impl,
    cli_args = {},
)

def _read_package_visibility_cap_impl(ctx):
    # No ancestor caps visibility at the root, so the cap is PUBLIC (no restriction).
    asserts.equals(bxl.read_package_visibility_cap("root//"), ["PUBLIC"])

    # `cap_dir` opts into intersection-based visibility, so its explicit
    # `package(visibility=...)` propagates as the cap. Exercise both input forms.
    cap_pkg_path = ctx.unconfigured_targets("root//cap_dir:cap_dummy").label.package_path
    asserts.equals(bxl.read_package_visibility_cap(cap_pkg_path), ["root//cap_dir/..."])
    asserts.equals(
        bxl.read_package_visibility_cap("root//cap_dir"),
        ["root//cap_dir/..."],
    )

    # `cap_dir/sub_dir` declares its own visibility but does not opt in, so its cap
    # is the one propagated from the `cap_dir` ancestor -- and is distinct from the
    # package's own visibility. This exercises ancestor->descendant cap propagation.
    asserts.equals(
        bxl.read_package_visibility_cap("root//cap_dir/sub_dir"),
        ["root//cap_dir/..."],
    )
    asserts.equals(
        bxl.read_package_visibility("root//cap_dir/sub_dir"),
        ["root//other:thing"],
    )

read_package_visibility_cap = bxl_main(
    impl = _read_package_visibility_cap_impl,
    cli_args = {},
)
